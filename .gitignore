# Local tool config and reference data — per-machine, never commit
.serena/
references/
reports/

# Real Claude Code session transcripts — PRIVATE (real conversations/paths) + huge, never commit.
# Tests bind-mount these locally in the devcontainer; a fresh clone uses the plan's E2E fallback.
# ROOT-ANCHORED (/) so it targets ONLY the top-level private-transcript dir — an unanchored `fixtures/`
# also shadowed test/fixtures/ (e.g. the C0 ledger-oracle safety net), silently un-tracking regenerated
# or newly-added committed fixtures. Anchoring un-shadows test/fixtures/ while keeping this dir ignored.
/fixtures/

node_modules/
*.log
.DS_Store

# Playwright default output dirs — regenerated on each E2E run, never commit
test-results/
playwright-report/
.playwright-mcp/

# 本机专用的 devcontainer 配置（Bedrock profile、OrbStack、本机路径），不入库
.devcontainer/

# Local Claude Code settings — per-machine permission allowlist with host paths, not shared
.claude/settings.local.json

# LaTeX build artifacts — never commit
*.aux
*.blg
*.out
*.bbl
*.log

# Development scripts and archived data — not part of the release
_archive/
arxiv-submit/
# Native worktrees created by the harness — per-session, never committed
.claude/worktrees/


# dist/ is tracked in git (bundled plugin artifacts)
!dist/
